# 复制为 .env 后填写。
# 不填写 AI_API_KEY 时，后端会自动使用 Mock 回退，项目仍可运行。

PORT=3000
INTERVIEW_DEMO=false
# 本地默认只监听 127.0.0.1。Docker 公网 Demo 才显式使用 BIND_HOST=0.0.0.0。
BIND_HOST=127.0.0.1
# 独立公网部署必须同时设置 PUBLIC_DEPLOYMENT=true、INTERVIEW_DEMO=true 和精确域名。
PUBLIC_DEPLOYMENT=false
# 逗号分隔的精确域名（可带端口），不支持通配符。
# Vercel 自动允许平台注入的部署域名；腾讯云等独立部署必须显式填写。
ALLOWED_HOSTS=
# 可选：不填写时分别使用 data/memory-museum.sqlite 与 data/media。
DB_PATH=
MEDIA_ROOT=
AI_BASE_URL=https://api.openai.com/v1
AI_MODEL=gpt-4.1-mini
AI_API_KEY=
AI_TIMEOUT_MS=20000
