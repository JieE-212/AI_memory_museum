# 复制为 .env 后填写。
# 不填写 AI_API_KEY 时，后端会自动使用 Mock 回退，项目仍可运行。

PORT=3000
INTERVIEW_DEMO=false
# 仅部署模式使用：逗号分隔的精确域名（可带端口），不支持通配符。
# Vercel 自动允许平台注入的部署域名；自定义域名需在此显式列出。
ALLOWED_HOSTS=
# 可选：不填写时分别使用 data/memory-museum.sqlite 与 data/media。
DB_PATH=
MEDIA_ROOT=
AI_BASE_URL=https://api.openai.com/v1
AI_MODEL=gpt-4.1-mini
AI_API_KEY=
AI_TIMEOUT_MS=20000
