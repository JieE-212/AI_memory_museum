# CloudBase 云托管公开 Demo 环境变量模板。
# 在控制台逐项填写；不要把此文件当作密钥文件上传。
# ALLOWED_HOSTS 只填写 CloudBase 访问 URL 的 hostname，不含 https://、路径或末尾斜杠。
# 下面的占位符含下划线，故意无法通过应用的 Host 配置校验；发布前必须替换。

NODE_ENV=production
PUBLIC_DEPLOYMENT=true
INTERVIEW_DEMO=true
BIND_HOST=0.0.0.0
PORT=3000
ALLOWED_HOSTS=REPLACE_WITH_EXACT_CLOUDBASE_HOST
DB_PATH=/tmp/ai-memory-museum-cloudbase-demo.sqlite
MEDIA_ROOT=/tmp/ai-memory-museum-cloudbase-demo-media
